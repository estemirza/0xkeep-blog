---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
    // 1. Grab all Markdown files
    const allPosts = await Astro.glob('../posts/*.md');

    // 2. Helper function to make URLs safe
    const slugify = (text: string) => text.toString().toLowerCase().replace(/\s+/g, '-').replace(/[^\w\-]+/g, '').replace(/\-\-+/g, '-').replace(/^-+/, '').replace(/-+$/, '');

    // 3. Define our permanent tags so Astro ALWAYS builds these pages, even if empty
    const predefinedTags =[
        "News", "Security", "Research", 
        "Projects", "Guides", "Developers", "Updates", "Cases"
    ];

    // 4. Also grab any custom tags you might have typed in Obsidian
    const postTags = allPosts.map((post) => post.frontmatter.tags ||[]).flat();

    // 5. Combine predefined tags + custom tags and remove duplicates
    const uniqueTags =[...new Set([...predefinedTags, ...postTags])];

    // 6. Generate a route for every tag
    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts.filter((post) => post.frontmatter.tags && post.frontmatter.tags.includes(tag));
        return {
            params: { tag: slugify(tag) },
            props: { posts: filteredPosts, tagName: tag },
        };
    });
}

// These are passed down from getStaticPaths
const { tag } = Astro.params;
const { posts, tagName } = Astro.props;

// Sort the filtered posts by newest first
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Layout title={`${tagName} Archives | 0xKeep Blog`}>
    
    <!-- Category Header Section -->
    <div class="text-center mb-20 fade-in-up">
        <div class="font-mono text-xs text-purple-400 uppercase tracking-widest mb-4">
            Category Archive
        </div>
        <h1 class="text-5xl md:text-7xl font-light tracking-tight mb-6 text-white">
            {tagName}
        </h1>
        <p class="text-lg text-zinc-400 font-light max-w-xl mx-auto leading-relaxed">
            Browsing all intercepted transmissions and research logs tagged with <span class="text-white font-medium">"{tagName}"</span>.
        </p>
    </div>

    <!-- Conditional Rendering: Show Empty State OR Grid of Posts -->
    {sortedPosts.length === 0 ? (
        
        /* --- EMPTY STATE UI --- */
        <div class="fade-in-up delay-100 max-w-2xl mx-auto text-center">
            <div class="glass-card p-12 flex flex-col items-center justify-center">
                <svg class="w-12 h-12 text-zinc-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
                <h3 class="text-2xl font-medium text-white mb-2">No Transmissions Yet</h3>
                <p class="text-zinc-400 font-light">There are currently no articles tagged with "{tagName}". Check back later.</p>
            </div>
        </div>

    ) : (

        /* --- POSTS GRID UI --- */
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 fade-in-up delay-100">
            {sortedPosts.map((post) => (
                <a href={post.url} class="glass-card p-8 group flex flex-col justify-between h-full hover:border-purple-500/30 transition-all duration-300">
                    <div>
                        <div class="flex flex-wrap gap-2 mb-4">
                            {post.frontmatter.tags && post.frontmatter.tags.map((t: string) => (
                                <span class="font-mono text-[10px] text-blue-400 uppercase tracking-widest border border-blue-500/20 rounded px-2 py-1 bg-blue-500/5 z-20">
                                    {t}
                                </span>
                            ))}
                        </div>
                        
                        <h3 class="text-2xl font-medium mb-3 text-white group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-purple-400 group-hover:to-blue-400 transition-all duration-300">
                            {post.frontmatter.title}
                        </h3>
                        
                        <p class="text-zinc-400 text-sm leading-relaxed mb-6">
                            {post.frontmatter.description}
                        </p>
                    </div>
                    
                    <div class="flex justify-between items-center pt-6 border-t border-white/5 mt-auto">
                        <div class="font-mono text-xs text-zinc-500">
                            {new Date(post.frontmatter.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                        </div>
                        <div class="text-purple-400 group-hover:translate-x-2 transition-transform duration-300">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </div>
                    </div>
                </a>
            ))}
        </div>

    )}

    <!-- Back to Home -->
    <div class="text-center mt-16 fade-in-up delay-200 border-t border-white/5 pt-10">
        <a href="/" class="text-zinc-400 hover:text-white font-mono text-sm uppercase tracking-widest transition-colors inline-flex items-center justify-center gap-2 border border-white/10 rounded-full px-6 py-3 hover:bg-white/5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            View All Transmissions
        </a>
    </div>

</Layout>